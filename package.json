{
  "name": "llog",
  "private": true,
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "android": "bunx concurrently --raw 'bun run:android' 'adb reverse tcp:8787 tcp:8787' 'bun dev:wrangler'",
    "build": "expo export --platform web --output-dir web && bun scripts/inject-theme.ts",
    "dev": "bunx concurrently --raw 'bun dev:expo' 'bun dev:wrangler'",
    "dev:expo": "expo start --offline --web --port 3000",
    "dev:wrangler": "wrangler dev --env development --ip 0.0.0.0",
    "doc": "bunx expo-doctor",
    "format": "prettier --write .",
    "ios": "bunx concurrently --raw 'bun run:ios' 'bun dev:wrangler'",
    "lint": "expo lint",
    "prebuild": "expo prebuild --clean",
    "push": "bun push:db && bun push:secrets && bun push:worker",
    "push:db": "NODE_ENV=production instant-cli push",
    "push:secrets": "wrangler secret bulk .dev.vars.production --env ''",
    "push:worker": "wrangler deploy --name llog --env production",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "theme": "bun scripts/generate-theme.ts",
    "types": "wrangler types --env development --env-interface CloudflareEnv",
    "up": "bun update --latest && bun i tailwindcss@3.4.17 eslint@~9.28.0 && expo install --fix",
    "watchman": "watchman watch-del $(pwd) && watchman watch-project $(pwd)"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@instantdb/admin": "0.22.158",
    "@instantdb/react-native": "0.22.158",
    "@legendapp/list": "^2.0.19",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/stack": "^7.8.5",
    "@rn-primitives/alert-dialog": "^1.2.0",
    "@rn-primitives/dropdown-menu": "^1.2.0",
    "@rn-primitives/label": "^1.2.0",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/radio-group": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/toggle": "^1.2.0",
    "@rn-primitives/types": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "^55.0.6",
    "expo-application": "^55.0.9",
    "expo-constants": "^55.0.7",
    "expo-image": "^55.0.6",
    "expo-image-manipulator": "^55.0.10",
    "expo-image-picker": "^55.0.12",
    "expo-linking": "^55.0.7",
    "expo-router": "^55.0.5",
    "expo-secure-store": "^55.0.8",
    "expo-system-ui": "^55.0.9",
    "hono": "^4.12.7",
    "nativewind": "^4.2.2",
    "phosphor-react-native": "^3.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "0.2.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sortables": "^1.9.4",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "react-textarea-autosize": "^8.5.9",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@expo/metro-runtime": "^55.0.6",
    "@types/chroma-js": "^3.1.2",
    "@types/react": "~19.2.14",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "chroma-js": "^3.2.0",
    "eslint": "~9.28.0",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "expo-dev-client": "^55.0.16",
    "instant-cli": "0.22.158",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3",
    "wrangler": "^4.73.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "patchedDependencies": {
    "react-native-css-interop@0.2.2": "patches/react-native-css-interop@0.2.2.patch"
  }
}

{
  "name": "llog",
  "private": true,
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "android": "bunx concurrently --raw 'bun run:android' 'bun dev:worker'",
    "build:web": "bun run generate:assets && expo export --platform web --output-dir web",
    "dev:tunnel": "source .env.development && cloudflared tunnel --loglevel debug run --token $CLOUDFLARED_TOKEN",
    "dev:worker": "wrangler dev --ip 0.0.0.0",
    "doc": "bunx expo-doctor",
    "format": "prettier --write .",
    "generate:assets": "bun scripts/generate-theme.ts && bun scripts/generate-media.tsx && bun scripts/generate-html.ts",
    "generate:vapid": "bunx @pushforge/builder vapid",
    "ios": "bunx concurrently --raw 'bun run:ios' 'bun dev:worker'",
    "lint": "expo lint && tsc --noEmit",
    "prebuild": "bun run generate:assets && expo prebuild --clean",
    "push": "bun push:db && bun push:secrets && bun push:worker",
    "push:db": "NODE_ENV=production instant-cli push -y",
    "push:secrets": "wrangler secret bulk .dev.vars.production --env ''",
    "push:worker": "wrangler deploy --name llog --env production",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "run:web": "expo start --offline --web",
    "types": "wrangler types --env-interface CloudflareEnv",
    "up": "bun update --latest && expo install --fix",
    "watchman": "watchman watch-del $(pwd) && watchman watch-project $(pwd)",
    "web": "bunx concurrently --raw 'bun run:web' 'bun dev:worker'"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@cloudflare/workers-types": "^4.20260420.1",
    "@expo/metro-runtime": "^55.0.9",
    "@hono/zod-validator": "^0.7.6",
    "@instantdb/admin": "1.0.11",
    "@instantdb/react-native": "1.0.11",
    "@legendapp/list": "^2.0.19",
    "@pushforge/builder": "^2.0.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/stack": "^7.8.10",
    "@resvg/resvg-js": "^2.6.2",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/types": "^1.4.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/chroma-js": "^3.1.2",
    "@types/linkify-it": "^5.0.0",
    "@types/react": "~19.2.14",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "~10.2.1",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "expo": "^55.0.15",
    "expo-asset": "~55.0.15",
    "expo-audio": "^55.0.13",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "^55.0.14",
    "expo-dev-client": "^55.0.27",
    "expo-document-picker": "^55.0.13",
    "expo-image": "^55.0.8",
    "expo-image-manipulator": "^55.0.15",
    "expo-image-picker": "^55.0.18",
    "expo-linking": "^55.0.13",
    "expo-router": "^55.0.12",
    "expo-system-ui": "^55.0.15",
    "expo-video": "^55.0.15",
    "hls.js": "^1.6.16",
    "hono": "^4.12.14",
    "instant-cli": "1.0.11",
    "linkify-it": "^5.0.0",
    "minisearch": "^7.2.0",
    "nanoid": "^5.1.9",
    "phosphor-react-native": "^3.0.4",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sortables": "^1.9.4",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "react-textarea-autosize": "^8.5.9",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tlds": "^1.261.0",
    "typescript": "~5.9.2",
    "uniwind": "^1.6.2",
    "wrangler": "^4.84.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}

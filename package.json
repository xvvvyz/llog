{
  "name": "llog",
  "private": true,
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "build:android": "expo run:android --no-bundler",
    "build:ios": "expo run:ios --no-bundler",
    "build:web": "expo export --platform web --output-dir web",
    "dev": "bunx concurrently --raw --kill-others-on-fail 'bun metro:start' 'bun worker'",
    "dev:android": "bunx concurrently --raw --kill-others-on-fail 'bun metro:android' 'bun worker'",
    "dev:ios": "bunx concurrently --raw --kill-others-on-fail 'bun metro:ios' 'bun worker'",
    "doc": "bunx expo-doctor",
    "format": "bun scripts/format.ts",
    "generate:assets": "bun scripts/assets.ts",
    "generate:vapid": "bunx @pushforge/builder vapid",
    "lint": "oxfmt --check . && oxlint --deny-warnings . && tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "metro:start": "expo start --offline",
    "metro:android": "expo start --dev-client --android --offline",
    "metro:ios": "expo start --dev-client --ios --offline",
    "prebuild:android": "expo prebuild --clean -p android && bun run generate:assets --android",
    "prebuild:ios": "expo prebuild --clean -p ios && bun run generate:assets --ios",
    "prebuild:web": "bun run generate:assets --web",
    "push": "bun push:db && bun push:secrets && bun push:worker",
    "push:db": "NODE_ENV=production instant-cli push -y",
    "push:secrets": "wrangler secret bulk .dev.vars.production --env ''",
    "push:worker": "bun build:web && wrangler deploy --name llog --env production",
    "reprocess:audd": "bun scripts/reprocess-audd.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "tunnel": "source .env.development && cloudflared tunnel --loglevel debug run --token $CLOUDFLARED_TOKEN",
    "types": "wrangler types --env-interface CloudflareEnv",
    "up": "bun update --latest && expo install --fix --bun && expo install --check",
    "watchman": "watchman watch-del $(pwd) && watchman watch-project $(pwd)",
    "worker": "wrangler dev --ip 0.0.0.0"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.5.0",
    "@expo/metro-runtime": "^55.0.11",
    "@hono/zod-validator": "^0.8.0",
    "@instantdb/admin": "1.0.27",
    "@instantdb/react-native": "1.0.27",
    "@legendapp/list": "^2.0.19",
    "@likashefqet/react-native-image-zoom": "^4.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pushforge/builder": "^2.0.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/types": "^1.4.0",
    "agents": "^0.12.3",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~55.0.23",
    "expo-asset": "~55.0.17",
    "expo-audio": "^55.0.14",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "^55.0.16",
    "expo-dev-client": "^55.0.32",
    "expo-document-picker": "^55.0.13",
    "expo-file-system": "~55.0.19",
    "expo-image": "^55.0.10",
    "expo-image-manipulator": "^55.0.16",
    "expo-image-picker": "^55.0.20",
    "expo-linking": "^55.0.15",
    "expo-router": "^55.0.14",
    "expo-splash-screen": "~55.0.20",
    "expo-system-ui": "^55.0.17",
    "expo-video": "^55.0.16",
    "hls.js": "^1.6.16",
    "hono": "^4.12.18",
    "linkify-it": "^5.0.0",
    "minisearch": "^7.2.0",
    "nanoid": "^5.1.11",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sortables": "^1.9.4",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.4",
    "react-textarea-autosize": "^8.5.9",
    "react-zoom-pan-pinch": "^4.0.3",
    "tailwind-merge": "^3.6.0",
    "tlds": "^1.261.0",
    "uniwind": "^1.6.4",
    "zod": "^4.4.3"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "4.3.0",
    "@types/bun": "^1.3.13",
    "@types/chroma-js": "^3.1.2",
    "@types/linkify-it": "^5.0.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "instant-cli": "1.0.27",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "postcss": "^8.5.14",
    "satori": "^0.26.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.2",
    "wrangler": "^4.90.1"
  }
}

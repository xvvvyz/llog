{
  "name": "llog",
  "private": true,
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "android": "bunx concurrently --raw 'bun run:android' 'adb reverse tcp:8787 tcp:8787' 'bun dev:wrangler'",
    "build:web": "expo export --platform web --output-dir web",
    "dev": "bun watchman && bunx concurrently --raw 'bun dev:expo' 'bun dev:wrangler'",
    "dev:expo": "expo start --offline",
    "dev:wrangler": "wrangler dev --env development --experimental-images-local-mode",
    "doc": "bunx expo-doctor",
    "format": "prettier --write .",
    "ios": "bunx concurrently --raw 'bun run:ios' 'bun dev:wrangler'",
    "lint": "expo lint",
    "prebuild": "expo prebuild --clean",
    "push:dev:db": "NODE_ENV=development instant-cli push",
    "push:prod": "bun push:prod:db && bun push:prod:secrets && bun push:prod:worker",
    "push:prod:db": "NODE_ENV=production instant-cli push",
    "push:prod:secrets": "wrangler secret bulk .dev.vars.production --env ''",
    "push:prod:worker": "wrangler deploy --name llog --env production",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "theme": "bun scripts/generate-theme.ts",
    "types": "wrangler types --env development --env-interface CloudflareEnv",
    "up": "bun update --latest && bun i tailwindcss@3.4.17 && expo install --fix",
    "watchman": "watchman watch-del $(pwd) && watchman watch-project $(pwd)"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.1",
    "@ai-sdk/google": "^2.0.3",
    "@ai-sdk/openai": "^2.0.7",
    "@ai-sdk/xai": "^2.0.3",
    "@hono/zod-validator": "^0.7.2",
    "@instantdb/admin": "0.20.21",
    "@instantdb/react-native": "0.20.21",
    "@legendapp/list": "^1.1.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.6.2",
    "@react-navigation/stack": "^7.4.5",
    "@rn-primitives/alert-dialog": "^1.2.0",
    "@rn-primitives/dropdown-menu": "^1.2.0",
    "@rn-primitives/label": "^1.2.0",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/toggle": "^1.2.0",
    "@rn-primitives/types": "^1.2.0",
    "agents": "^0.0.111",
    "ai": "^5.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "^53.0.20",
    "expo-application": "^6.1.5",
    "expo-constants": "^17.1.7",
    "expo-image": "^2.4.0",
    "expo-image-manipulator": "^13.1.7",
    "expo-image-picker": "^16.1.4",
    "expo-linking": "^7.1.7",
    "expo-router": "^5.1.4",
    "expo-secure-store": "^14.2.3",
    "expo-system-ui": "^5.0.10",
    "hono": "^4.9.0",
    "hono-agents": "^0.0.101",
    "lucide-react-native": "^0.539.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-sortables": "^1.8.0",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0",
    "react-textarea-autosize": "^8.5.9",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@cloudflare/workers-types": "^4.20250807.0",
    "@expo/metro-runtime": "^5.0.4",
    "@types/chroma-js": "^3.1.1",
    "@types/react": "~19.0.10",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "chroma-js": "^3.1.2",
    "eslint": "^9.32.0",
    "eslint-config-expo": "^9.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "expo-dev-client": "^5.2.4",
    "instant-cli": "0.20.21",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "~5.8.3",
    "wrangler": "^4.28.1"
  },
  "resolutions": {
    "react": "19.0.0"
  },
  "patchedDependencies": {
    "uuid@9.0.1": "patches/uuid@9.0.1.patch"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}

{
  "expo": {
    "name": "llog",
    "slug": "llog",
    "version": "0.0.1",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "scheme": "llog",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "co.xvyz.llog"
    },
    "android": {
      "package": "co.xvyz.llog",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single",
      "outputDirectory": "web"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "./plugins/with-remove-duplicate-libcxx-linker-flag"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

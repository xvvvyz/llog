{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-05-25",
  "compatibility_flags": ["nodejs_compat"],
  "name": "llog",
  "main": "api/index.ts",
  "env": {
    "development": {
      "r2_buckets": [
        {
          "binding": "R2",
          "bucket_name": "llog",
          "remote": true,
        },
      ],
      "vars": {
        "ENV": "development",
      },
    },
    "production": {
      "assets": {
        "directory": "web",
        "not_found_handling": "single-page-application",
      },
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
      },
      "r2_buckets": [
        {
          "binding": "R2",
          "bucket_name": "llog",
        },
      ],
      "vars": {
        "ENV": "production",
      },
    },
  },
}

{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "phosphor-react-native/lib/module/icons/*": [
        "./node_modules/phosphor-react-native/lib/typescript/icons/*"
      ]
    },
    "strict": true
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "uniwind-types.d.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": ["node_modules", "scripts"]
}
